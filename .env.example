# ==============================================================================
# Voices of Home — environment template
# Copy to .env and fill in real values. NEVER commit your real .env.
# ==============================================================================

# --- ASI:One (PRIMARY chat provider — Fetch.ai track) ---
# Used for: care assistant chat AND mental wellness chat (asi1-ultra)
# Get a key at https://asi1.ai (or via Agentverse account)
ASI_ONE_API_KEY=your_asi_one_key

# --- ANTHROPIC CLAUDE (FALLBACK chat provider — MLH Claude credits) ---
# Used as a fallback when ASI:One is unreachable.
# ANTHROPIC_API_KEY=your_anthropic_api_key

# --- GOOGLE GEMINI (MLH Challenge — Google Swag) ---
# Used for: cultural symptom RAG, food vision, simplification, embeddings
GOOGLE_API_KEY=your_gemini_api_key
# Optional: switch model if 2.0-flash hits limit:0
# GEMINI_MODEL=gemini-1.5-flash

# --- ELEVENLABS (MLH Challenge — Wireless Earbuds) ---
# Used for: multilingual voice synthesis (eleven_multilingual_v2)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- CLOUDINARY (Company Challenge — $2,000) ---
# Used for: food photo upload + AI tagging + CDN
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- MONGODB ATLAS (MLH Challenge — Atlas swag) ---
# Used for: hospitals, doctors, patients, sessions, care circles, vector search
# Get the URI from Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/voicesofhome?retryWrites=true&w=majority
# Vector Search index name (create in Atlas → Search → Vector Search)
ATLAS_VECTOR_INDEX=cultural_kb_vector

# --- FETCH.AI / AGENTVERSE (Company Challenge — $5,000) ---
# Used for: voh-symptom-agent, voh-food-agent, voh-voice-agent, voh-orchestrator-agent
# SEED is a long random hex string (openssl rand -hex 32). Keep it stable.
FETCH_AGENT_SEED_PHRASE=your_agent_seed_phrase
FETCH_AGENTVERSE_API_KEY=your_agentverse_key

# --- ZETIC / MELANGE (Company Challenge — $2,000) ---
# Used for: on-device Whisper speech-to-text (mobile only)
# MELANGE_PERSONAL_KEY=your_melange_key

# --- SERVER CONFIG ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
